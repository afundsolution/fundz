# Copy this to .env.local for local development.
# Never commit real secrets.

APP_ENV=local

# Local development data stays on this machine.
LOCAL_DATA_DIR=./data/local
LOCAL_EXPORT_DIR=./data/exports
LOCAL_LOG_DIR=./logs

# Production/user data should live in a managed database with automated backups.
# Examples:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fundz
# SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/fundz?sslmode=require
DATABASE_URL=
FUNDZ_MEMORY_DATABASE_URL=
SUPABASE_DB_URL=
NEON_DATABASE_URL=

# Optional secret-manager references for production deployments.
# Examples:
# SECRET_MANAGER_PROVIDER=aws-secrets-manager
# SECRET_MANAGER_REF=arn:aws:secretsmanager:us-east-1:123456789012:secret:fundz/prod
SECRET_MANAGER_PROVIDER=
SECRET_MANAGER_REF=

# Remote backup target.
# For rclone, configure a remote first, then set something like:
# RCLONE_REMOTE=fundz-backups:FUNDz
RCLONE_REMOTE=

# Local backup staging folder.
BACKUP_DIR=./backups

# Credit Tracker live auto-reply bridge.
# Set these in .env.local, not in Git.
FUNDZ_BRIDGE_HOST=127.0.0.1
FUNDZ_BRIDGE_PORT=8787

# Optional shared secret for incoming webhooks. If set, Credit Tracker must send
# X-FUNDZ-Signature: sha256=<hex hmac sha256 body signature>.
CREDIT_TRACKER_WEBHOOK_SECRET=

# Outbound Credit Tracker/GoHighLevel reply API.
CREDIT_TRACKER_REPLY_URL=https://services.leadconnectorhq.com/conversations/messages
CREDIT_TRACKER_API_TOKEN=
CREDIT_TRACKER_LOCATION_ID=
CREDIT_TRACKER_FIREBASE_API_KEY=
CREDIT_TRACKER_REFRESH_TOKEN=
CREDIT_TRACKER_AUTH_SCHEME=Bearer
CREDIT_TRACKER_TIMEOUT=12
CREDIT_TRACKER_USER_AGENT=FUNDzCreditTrackerBridge/1.0
CREDIT_TRACKER_HTTP_TRANSPORT=auto

# Keep true until the real outbound endpoint is configured and tested.
CREDIT_TRACKER_DRY_RUN=true
CREDIT_TRACKER_DEFAULT_MESSAGE_TYPE=SMS

# Set true only if the inbound webhook payload includes credit-tracker text or channel data.
CREDIT_TRACKER_REQUIRE_CHANNEL=false

# Optional: only auto-reply once per contact until data/local/credit-tracker-bridge/seen-events.txt is cleared.
CREDIT_TRACKER_REPLY_ONCE_PER_CONTACT=false

# JSON object sent to CREDIT_TRACKER_REPLY_URL. Available placeholders:
# {message}, {contact_id}, {conversation_id}, {phone}, {email},
# {client_first_name}, {inbound_message}, plus any inbound payload field.
CREDIT_TRACKER_OUTBOUND_TEMPLATE={"type":"{message_type}","contactId":"{contact_id}","message":"{message}"}

# Optional JSON object with provider-specific headers.
CREDIT_TRACKER_OUTBOUND_HEADERS={"Version":"2021-07-28","Accept":"application/json"}

# HighLevel inbox fallback. This lets FUNDz poll inbound client texts directly
# from HighLevel when Cloudflare/webhook delivery is unavailable.
HIGHLEVEL_CONVERSATIONS_URL=https://services.leadconnectorhq.com/conversations/search
HIGHLEVEL_INBOX_STATUS=unread
HIGHLEVEL_INBOX_LIMIT=20
HIGHLEVEL_INBOX_INTERVAL=60
HIGHLEVEL_INBOX_LAST_DIRECTION=inbound
HIGHLEVEL_INBOX_EXTRA_PARAMS=
FUNDZ_HIGHLEVEL_POLLER_LIVE=false

# If HighLevel API scopes are blocked, export/copy business-only conversation
# rows to data/local/highlevel-inbox-manual-imports/ and run
# `make highlevel-inbox-workaround`. No replies are sent from that path.

# Local PR-gated autonomy loop. It can diagnose, quarantine, retry, and propose
# improvements, but must not apply code changes automatically.
FUNDZ_AUTONOMY_ENABLED=false
FUNDZ_AUTONOMY_INTERVAL_SECONDS=300
FUNDZ_AUTONOMY_RETRY_LIMIT=2
FUNDZ_AUTONOMY_FAILURE_THRESHOLD=3
FUNDZ_AUTONOMY_PROPOSE_CODE_CHANGES=true
FUNDZ_AUTONOMY_APPLY_CODE_CHANGES=false

# Safe local autonomous operator. It runs command-center, intake, maintenance,
# and proposal/quarantine review without starting live sends or live pollers.
FUNDZ_AUTONOMOUS_OPERATOR_ENABLED=false
FUNDZ_AUTONOMOUS_OPERATOR_INTERVAL_SECONDS=900
FUNDZ_ALLOW_IMESSAGE_FALLBACK_LAUNCHAGENT=true

# Semi-autonomous operating loop. This builds queues and pilot packets locally.
# Live pilot sends still require explicit approval at action time.
FUNDZ_SEMI_AUTONOMOUS_INTERVAL_SECONDS=300
FUNDZ_BATCH_SIZE=3
FUNDZ_BATCH_MAX_SIZE=5
FUNDZ_BATCH_CHANNEL=Email
FUNDZ_BATCH_EMAIL_SUBJECT=FUNDz update
FUNDZ_BATCH_PRESET=safe_expansion
# Live sends are blocked on weekends and outside 9 AM - 9 PM local time unless
# Brandon explicitly sets this true for a specific approved action window.
FUNDZ_ALLOW_AFTER_HOURS_SENDS=false
# Owner text notice before any approved live send. The live send runner sends
# Brandon an iMessage first, blocks the client send, and requires the notice to
# be at least 120 seconds old before the send can proceed on the next run.
FUNDZ_OWNER_NOTIFY_TARGET=
FUNDZ_OWNER_PRE_SEND_NOTICE_SECONDS=120
FUNDZ_OWNER_PRE_SEND_NOTICE_LIVE=true

# AutoFox/Credit Tracker portal/app message workflow handoff.
# The normal HighLevel conversations API sends SMS/email. To make a message show
# inside the Credit Tracker app/portal, configure the matching AutoFox/Credit
# Tracker workflow and set either its workflow ID or the tag it watches.
AUTOFOX_PORTAL_WORKFLOW_ID=
AUTOFOX_PORTAL_TRIGGER_TAG=

# Optional: if the AutoFox workflow reads the portal message from a custom contact
# field, set that field id/key so FUNDz can update it before triggering workflow.
AUTOFOX_PORTAL_MESSAGE_FIELD_ID=
AUTOFOX_PORTAL_MESSAGE_FIELD_KEY=

# Protected owner-command mode for iMessage-style instructions.
# Add Brandon's owner phone number(s), comma-separated, to require sender allowlist checks.
# Example: FUNDZ_OWNER_COMMAND_SENDERS=+18325551234
FUNDZ_OWNER_COMMAND_SENDERS=

# Local-first AI router for owner questions.
# Default: use local AI first, currently Ollama if installed. Paid/cloud AI is off
# unless you turn it on and add a provider key. Sensitive client/money/credit/
# phone/inbox text stays local by default.
FUNDZ_AI_LOCAL_ENABLED=true
FUNDZ_AI_LOCAL_MODEL=llama3.2:3b
FUNDZ_AI_PAID_ENABLED=false
FUNDZ_AI_PAID_PROVIDER=openai
FUNDZ_AI_PAID_MODEL=gpt-5.4-mini
FUNDZ_AI_PAID_AUTO_FOR_SAFE=true
FUNDZ_AI_PAID_ALLOW_SENSITIVE=false
FUNDZ_AI_TIMEOUT_SECONDS=90
FUNDZ_AI_MAX_OUTPUT_TOKENS=600
# OPENAI_API_KEY=
# GROQ_API_KEY=

# Named Cloudflare tunnel setup. Set after Cloudflare login if you have a domain
# in the Cloudflare account, for example: fundz.yourdomain.com
FUNDZ_TUNNEL_NAME=fundz-credit-tracker
FUNDZ_TUNNEL_HOSTNAME=
FUNDZ_COMMAND_CENTER_HOSTNAME=fundz-command.afundsolution.com
FUNDZ_COMMAND_CENTER_PORT=8797
# Safe-autonomy allow flag for the protected Command Center domain server/tunnel.
FUNDZ_ALLOW_COMMAND_CENTER_DOMAIN_TUNNEL=true
# Optional override. If empty, the local domain setup creates a private owner token
# at data/local/command-center/fundz-command-center-domain.json.
FUNDZ_COMMAND_CENTER_TOKEN=
