# Copy this to .env.local for local development.
# Never commit real secrets.

APP_ENV=local

# Local development data stays on this machine.
LOCAL_DATA_DIR=./data/local
LOCAL_EXPORT_DIR=./data/exports
LOCAL_LOG_DIR=./logs

# Production/user data should live in a managed database with automated backups.
# Examples:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fundz
# SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/fundz?sslmode=require
DATABASE_URL=

# Optional secret-manager references for production deployments.
# Examples:
# SECRET_MANAGER_PROVIDER=aws-secrets-manager
# SECRET_MANAGER_REF=arn:aws:secretsmanager:us-east-1:123456789012:secret:fundz/prod
SECRET_MANAGER_PROVIDER=
SECRET_MANAGER_REF=

# Remote backup target.
# For rclone, configure a remote first, then set something like:
# RCLONE_REMOTE=fundz-backups:FUNDz
RCLONE_REMOTE=

# Local backup staging folder.
BACKUP_DIR=./backups

# Credit Tracker live auto-reply bridge.
# Set these in .env.local, not in Git.
FUNDZ_BRIDGE_HOST=127.0.0.1
FUNDZ_BRIDGE_PORT=8787

# Optional shared secret for incoming webhooks. If set, Credit Tracker must send
# X-FUNDZ-Signature: sha256=<hex hmac sha256 body signature>.
CREDIT_TRACKER_WEBHOOK_SECRET=

# Outbound Credit Tracker/GoHighLevel reply API.
CREDIT_TRACKER_REPLY_URL=https://services.leadconnectorhq.com/conversations/messages
CREDIT_TRACKER_API_TOKEN=
CREDIT_TRACKER_AUTH_SCHEME=Bearer
CREDIT_TRACKER_TIMEOUT=12

# Keep true until the real outbound endpoint is configured and tested.
CREDIT_TRACKER_DRY_RUN=true
CREDIT_TRACKER_DEFAULT_MESSAGE_TYPE=SMS

# Set true only if the inbound webhook payload includes credit-tracker text or channel data.
CREDIT_TRACKER_REQUIRE_CHANNEL=false

# Optional: only auto-reply once per contact until data/local/credit-tracker-bridge/seen-events.txt is cleared.
CREDIT_TRACKER_REPLY_ONCE_PER_CONTACT=false

# JSON object sent to CREDIT_TRACKER_REPLY_URL. Available placeholders:
# {message}, {contact_id}, {conversation_id}, {phone}, {email},
# {client_first_name}, {inbound_message}, plus any inbound payload field.
CREDIT_TRACKER_OUTBOUND_TEMPLATE={"type":"{message_type}","contactId":"{contact_id}","message":"{message}"}

# Optional JSON object with provider-specific headers.
CREDIT_TRACKER_OUTBOUND_HEADERS={"Version":"2021-04-15","Accept":"application/json"}
