# Local secrets
.env
.env.*
!.env.example

# Local runtime data
data/local/*
!data/local/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/dispute-fox/*
!data/dispute-fox/.gitkeep
logs/*
!logs/.gitkeep

# Backups are generated locally and can be copied to remote storage.
backups/*
!backups/.gitkeep

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Common dependency/build folders
node_modules/
dist/
build/
.next/
.turbo/
coverage/
__pycache__/
*.pyc
